{
 "compilerOptions": {
  "target": "ES6",
  "module": "NodeNext",
  "moduleResolution": "NodeNext",
  "lib": ["ES6", "dom"],
  "sourceMap": true,
  "strict": true,
  "noImplicitAny": true,
  "esModuleInterop": true,
  "resolveJsonModule": true,
  "allowJs": true,
  "rootDir": "src",
  "outDir": "dist"
 },
 "include": ["src/**/*"]
}